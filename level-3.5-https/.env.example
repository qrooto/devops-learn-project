# Скопируй в .env и поменяй значения: cp .env.example .env
# .env в .gitignore и не попадает в Git. Docker Compose читает его автоматически.
# Значения ниже — учебные плейсхолдеры, на реальном сервере обязательно замени.
POSTGRES_DB=bulletin_board
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Ключ подписи JWT — сгенерируй свой: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-env-secrets
