# ── Claude API ─────────────────────────────────────────────────────────────────
# Получить на: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-api03-ЗАМЕНИ_НА_СВОЙ_КЛЮЧ

# Версия модели — можно менять на более новую по мере выхода
CLAUDE_MODEL=claude-sonnet-4-6


# ── Telegram Bot ───────────────────────────────────────────────────────────────
# 1. Открой @BotFather в Telegram → /newbot → получи токен
# 2. Напиши боту любое сообщение (иначе getUpdates вернёт пустой список)
# 3. Получи chat_id:
#    curl https://api.telegram.org/bot<TOKEN>/getUpdates | python3 -m json.tool
#    Ищи: result[0].message.chat.id
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=-100123456789


# ── Внутренние сервисы (через Docker network) ──────────────────────────────────
# Имена сервисов из level-6-monitoring/docker-compose.yml
PROMETHEUS_URL=http://prometheus:9090
LOKI_URL=http://loki:3100
