{
  "schema_version": 1,
  "diagram_type": "architecture",
  "meta": {
    "title": "Level 4 (GitLab) — сетевой путь",
    "subtitle": "Новые published-порты: 8929 (HTTP) и 2222 (git SSH)",
    "output": "network.html"
  },
  "components": [
    {
      "id": "dev",
      "type": "external",
      "label": "Разработчик",
      "sublabel": "git push / браузер",
      "pos": [
        40,
